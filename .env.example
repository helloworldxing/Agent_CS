# Example env for Agent-Pr (do NOT include secrets in repo)

# Ollama 本地模型名称（可选）
OLLAMA_MODEL=your-ollama-model-name

# 云模型服务 API key（例如 DashScope）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# OpenAI API key（如使用 OpenAI）
OPENAI_API_KEY=your_openai_api_key_here

# Optional: explicit ffmpeg exe path from imageio-ffmpeg on Windows
IMAGEIO_FFMPEG_EXE=C:\path\to\ffmpeg.exe
